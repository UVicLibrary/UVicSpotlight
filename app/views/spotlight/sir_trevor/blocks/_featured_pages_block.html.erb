<%# OVERRIDE blacklight-spotlight v.5.0.1 %>
<%# Pass current_ability to FeaturedPagesBlock and add a gradient to the 
    bottom of the page block to make the text more visible %>
<% if featured_pages_block.pages?(current_ability) %>
  <% pages = featured_pages_block.pages(current_ability) %>
  <div class="spotlight-flexbox browse-categories categories-<%= pages.length %>" data-sidebar='<%= @page.display_sidebar? %>'>
    <% pages.each_with_index do |page, index| %>
      <div class="box category-<%= (index + 1) %>">
        <%= link_to [spotlight, current_exhibit, page] do %>
          <div class="browse-category" style='background-image: linear-gradient(rgba(0, 0, 0, 0.0), rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.8)) <%= ", url(\"#{page.thumbnail_image_url}\")" if page.thumbnail_image_url %><%= "; width:104%" if pages.length == 2 %>'>
            <div class="category-caption">
              <p class="category-title">
                <%= page.title %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
