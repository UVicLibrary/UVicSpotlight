<% if show_sort_and_per_page? %>
  <%= render(Blacklight::Response::SortComponent.new(
    choices: active_sort_fields.map { |key, config| [(config.try(:original).present? ? config.original.label : config.label), key]},
    search_state: search_state,
    selected: current_sort_field&.key)) %>
<% end %>
